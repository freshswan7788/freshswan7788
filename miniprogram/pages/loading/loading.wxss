.container { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; padding: 60rpx 30rpx; }
.loading-box { display: flex; flex-direction: column; align-items: center; margin-bottom: 80rpx; }
.spinner { width: 80rpx; height: 80rpx; border: 6rpx solid #e8e8e8; border-top-color: #2d8cf0; border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 30rpx; }
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text { font-size: 32rpx; color: #333; font-weight: bold; margin-bottom: 10rpx; }
.countdown { font-size: 24rpx; color: #999; }

.ad-area { width: 100%; max-width: 600rpx; }
.ad-label { font-size: 22rpx; color: #ccc; text-align: center; margin-bottom: 10rpx; }
.ad-box { width: 100%; height: 300rpx; background: #fff; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.ad-placeholder-text { font-size: 26rpx; color: #ccc; }
