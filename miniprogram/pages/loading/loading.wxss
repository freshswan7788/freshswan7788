.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 30rpx;
  box-sizing: border-box;
}

/* 加载动画区域 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

/* 圆环动画 */
.loading-circle {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.spinner {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 8rpx solid #e0e0e0;
  border-top: 8rpx solid #667eea;
  border-radius: 50%;
  animation: spin 1.2s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-icon {
  font-size: 60rpx;
  z-index: 1;
}

/* 文字 */
.loading-text {
  font-size: 34rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.countdown-text {
  font-size: 26rpx;
  color: #999;
}

/* 广告位 */
.ad-placeholder {
  width: 100%;
  max-width: 600rpx;
}

.ad-label {
  font-size: 22rpx;
  color: #bbb;
  text-align: center;
  margin-bottom: 12rpx;
}

.ad-box {
  width: 100%;
  min-height: 300rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.ad-mock {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

.ad-mock-text {
  font-size: 28rpx;
  color: #999;
}
