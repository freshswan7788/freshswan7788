/* 加载页 - 卡通可爱风 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 30rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  animation: float 6s ease-in-out infinite;
}

.bg-circle-1 {
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 154, 158, 0.15), transparent);
  top: -60rpx;
  right: -80rpx;
  animation-delay: 0s;
}

.bg-circle-2 {
  width: 220rpx;
  height: 220rpx;
  background: radial-gradient(circle, rgba(254, 207, 239, 0.12), transparent);
  bottom: 240rpx;
  left: -60rpx;
  animation-delay: 2s;
}

.bg-circle-3 {
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(161, 140, 209, 0.1), transparent);
  bottom: -30rpx;
  right: 80rpx;
  animation-delay: 4s;
}

@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20rpx) scale(1.05); }
}

/* 加载动画区域 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  position: relative;
  z-index: 1;
}

/* 多层旋转圆环 */
.rings-container {
  width: 240rpx;
  height: 240rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 50rpx;
}

.ring {
  position: absolute;
  border-radius: 50%;
  border: 5rpx solid transparent;
}

.ring-outer {
  width: 240rpx;
  height: 240rpx;
  border-top-color: #ff9a9e;
  border-right-color: rgba(255, 154, 158, 0.3);
  animation: spin 2s linear infinite;
}

.ring-middle {
  width: 180rpx;
  height: 180rpx;
  border-bottom-color: #fecfef;
  border-left-color: rgba(254, 207, 239, 0.3);
  animation: spinReverse 1.5s linear infinite;
}

.ring-inner {
  width: 120rpx;
  height: 120rpx;
  border-top-color: #a18cd1;
  border-right-color: rgba(161, 140, 209, 0.3);
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

@keyframes spinReverse {
  0% { transform: rotate(360deg); }
  100% { transform: rotate(0deg); }
}

.center-icon {
  font-size: 60rpx;
  z-index: 1;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

/* 文字区域 */
.loading-title {
  font-size: 36rpx;
  color: #4a3f5c;
  font-weight: 700;
  margin-bottom: 16rpx;
}

/* 加载点 */
.loading-dots {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff9a9e;
  animation: dotBounce 1.4s ease-in-out infinite;
}

.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.2s; }
.dot-3 { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1.2); opacity: 1; }
}

.countdown-text {
  font-size: 28rpx;
  color: #ff6b8a;
  font-weight: 600;
  padding: 10rpx 30rpx;
  background: #fff0f3;
  border-radius: 30rpx;
  border: 2rpx solid #ffe4e8;
}

/* 提示区域 */
.tips-section {
  margin-top: 40rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  animation: fadeInOut 3s ease-in-out infinite;
}

@keyframes fadeInOut {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #b8a9c9;
}

/* 广告区域 */
.ad-section {
  width: 100%;
  max-width: 620rpx;
  position: relative;
  z-index: 1;
}

.ad-label {
  font-size: 22rpx;
  color: #ddd;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.ad-box {
  width: 100%;
  min-height: 260rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(255, 154, 158, 0.08);
  border: 3rpx solid #ffe4e8;
}

.ad-placeholder {
  width: 100%;
  height: 260rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #fff5f7, #fef9ff);
}

.ad-icon {
  font-size: 48rpx;
  opacity: 0.5;
}

.ad-text {
  font-size: 26rpx;
  color: #c9b8d9;
}
