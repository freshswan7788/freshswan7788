.container { padding: 30rpx; padding-bottom: 180rpx; }
.header-tip { font-size: 28rpx; color: #333; font-weight: bold; margin-bottom: 30rpx; line-height: 1.6; }

/* 维度 */
.dimension { display: flex; align-items: center; margin-bottom: 20rpx; }
.dimension-dot { width: 8rpx; height: 32rpx; background: #2d8cf0; border-radius: 4rpx; margin-right: 14rpx; }
.dimension-text { font-size: 28rpx; color: #2d8cf0; font-weight: bold; }

/* 题目卡片 */
.question-card { background: #fff; border-radius: 12rpx; padding: 30rpx; margin-bottom: 30rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.question-num { font-size: 26rpx; color: #999; display: block; margin-bottom: 10rpx; }
.question-text { font-size: 30rpx; color: #333; line-height: 1.8; }

/* 横排选项标签 */
.options-row { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 40rpx; }
.option-tag { padding: 16rpx 28rpx; background: #f0f4ff; border: 2rpx solid #d6e4ff; border-radius: 8rpx; font-size: 26rpx; color: #2d8cf0; transition: all 0.2s; }
.option-tag:active { opacity: 0.8; }
.option-tag.active { background: #2d8cf0; color: #fff; border-color: #2d8cf0; }

/* 底部按钮栏 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; gap: 20rpx; padding: 20rpx 30rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); background: #f5f6fa; border-top: 1rpx solid #eee; z-index: 100; }
.btn-prev, .btn-next, .btn-submit { flex: 1; height: 80rpx; line-height: 80rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: bold; text-align: center; border: none; margin: 0; padding: 0; }
.btn-prev { background: #e8e8e8; color: #666; }
.btn-prev[disabled] { background: #f5f5f5; color: #ccc; }
.btn-next { background: #2d8cf0; color: #fff; }
.btn-next:active { background: #2074d4; }
.btn-submit { background: #2d8cf0; color: #fff; }
.btn-submit:active { background: #2074d4; }
