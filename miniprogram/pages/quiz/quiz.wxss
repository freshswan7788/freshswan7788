/* 答题页 - 卡通可爱风 */
.container {
  padding: 30rpx;
  padding-bottom: 200rpx;
  position: relative;
}

/* 顶部进度区域 */
.progress-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(255, 154, 158, 0.1);
  border: 3rpx solid #ffe4e8;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 26rpx;
  color: #b8a9c9;
}

.progress-count {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b8a;
}

.progress-track {
  width: 100%;
  height: 20rpx;
  background: #fff0f3;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff9a9e 0%, #fecfef 50%, #a18cd1 100%);
  border-radius: 10rpx;
  transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 题目头部提示 */
.quiz-header {
  font-size: 28rpx;
  color: #b8a9c9;
  margin-bottom: 24rpx;
  line-height: 1.6;
  text-align: center;
  padding: 0 20rpx;
}

/* 维度标签 */
.dimension-tag {
  display: inline-flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 12rpx 28rpx;
  background: #fff0f3;
  border-radius: 30rpx;
  border: 2rpx solid #ffe4e8;
}

.dimension-icon {
  width: 14rpx;
  height: 14rpx;
  background: #ff6b8a;
  border-radius: 50%;
  margin-right: 14rpx;
}

.dimension-text {
  font-size: 26rpx;
  color: #ff6b8a;
  font-weight: 600;
}

/* 题目卡片 */
.question-card {
  background: #fff;
  border-radius: 30rpx;
  padding: 36rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(255, 154, 158, 0.1);
  border: 3rpx solid #ffe4e8;
  position: relative;
  overflow: hidden;
  animation: fadeInUp 0.3s ease;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.question-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #ff9a9e, #fecfef, #a18cd1);
  border-radius: 30rpx 30rpx 0 0;
}

.question-number {
  display: inline-block;
  font-size: 24rpx;
  color: #ff6b8a;
  font-weight: bold;
  background: #fff0f3;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid #ffe4e8;
}

.question-text {
  font-size: 34rpx;
  color: #4a3f5c;
  line-height: 1.9;
  font-weight: 500;
}

/* 选项列表 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-bottom: 40rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: #fff;
  border: 3rpx solid #f0e8f5;
  border-radius: 24rpx;
  padding: 28rpx 30rpx;
  transition: all 0.25s ease;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.active {
  border-color: #ff9a9e;
  background: linear-gradient(135deg, #fff5f7, #fff0f5);
  box-shadow: 0 4rpx 16rpx rgba(255, 154, 158, 0.2);
}

.option-radio {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #e0d6ea;
  margin-right: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}

.option-item.active .option-radio {
  border-color: #ff9a9e;
  background: linear-gradient(135deg, #ff9a9e, #fecfef);
}

.radio-inner {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: transparent;
  transition: all 0.25s ease;
}

.option-item.active .radio-inner {
  background: #fff;
}

.option-content {
  display: flex;
  align-items: center;
  flex: 1;
}

.option-score {
  font-size: 30rpx;
  font-weight: bold;
  color: #c9b8d9;
  margin-right: 16rpx;
  min-width: 60rpx;
  transition: color 0.25s ease;
}

.option-item.active .option-score {
  color: #ff6b8a;
}

.option-label {
  font-size: 30rpx;
  color: #5a4f6a;
  transition: color 0.25s ease;
}

.option-item.active .option-label {
  color: #ff6b8a;
  font-weight: 600;
}

/* 底部导航按钮 */
.nav-buttons {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 245, 245, 0.95);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 -4rpx 20rpx rgba(255, 154, 158, 0.1);
  border-top: 2rpx solid #ffe4e8;
  z-index: 100;
}

.nav-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
  font-weight: 600;
  margin: 0;
  padding: 0;
}

.prev-btn {
  background: #f8f0ff;
  color: #9b8ab8;
  border: 2rpx solid #e8dcf5;
}

.prev-btn:active {
  background: #f0e4ff;
}

.prev-btn[disabled] {
  background: #fafafa;
  color: #ddd;
  border-color: #f0f0f0;
}

.next-btn {
  background: #ff6b8a;
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 138, 0.3);
}

.next-btn:active {
  transform: scale(0.97);
  background: #ff5277;
}

.submit-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  padding: 0;
  margin: 0;
  background: #ff6b8a;
  color: #fff;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 138, 0.35);
  border: none;
}

.submit-btn:active {
  transform: scale(0.97);
}
