.container { padding: 30rpx; }

/* 分数区 */
.score-section { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0 30rpx; }
.score-icon { font-size: 80rpx; margin-bottom: 10rpx; }
.score-num { font-size: 72rpx; font-weight: 900; color: #2d8cf0; }
.score-unit { font-size: 28rpx; color: #999; margin-top: -10rpx; }
.score-label { margin-top: 16rpx; padding: 8rpx 30rpx; background: #2d8cf0; color: #fff; font-size: 26rpx; font-weight: bold; border-radius: 20rpx; }

/* 卡片 */
.card { background: #fff; border-radius: 12rpx; padding: 30rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.card-header { display: flex; align-items: center; margin-bottom: 16rpx; }
.card-dot { width: 8rpx; height: 30rpx; border-radius: 4rpx; margin-right: 12rpx; }
.card-dot.blue { background: #2d8cf0; }
.card-dot.green { background: #19be6b; }
.card-title { font-size: 30rpx; font-weight: bold; color: #333; }
.card-body { font-size: 28rpx; color: #555; line-height: 2; }

/* 按钮组 */
.btn-group { margin-top: 40rpx; display: flex; flex-direction: column; gap: 20rpx; }
.btn-share { height: 88rpx; line-height: 88rpx; background: #2d8cf0; color: #fff; font-size: 30rpx; font-weight: bold; border-radius: 44rpx; border: none; }
.btn-share:active { background: #2074d4; }
.btn-retry { height: 80rpx; line-height: 80rpx; background: #fff; color: #666; font-size: 28rpx; border-radius: 40rpx; border: 2rpx solid #ddd; }
.btn-retry:active { background: #f9f9f9; }

/* 免责 */
.disclaimer { text-align: center; font-size: 22rpx; color: #bbb; margin-top: 30rpx; }

/* 底部推荐 */
.recommend { display: flex; justify-content: center; gap: 60rpx; margin-top: 40rpx; padding-top: 30rpx; border-top: 1rpx solid #eee; }
.rec-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.rec-icon { font-size: 40rpx; }
.rec-name { font-size: 22rpx; color: #999; }

/* 海报弹窗 */
.modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 999; background: rgba(0,0,0,0.6); display: flex; align-items: center; justify-content: center; opacity: 0; visibility: hidden; transition: all 0.3s; }
.modal.show { opacity: 1; visibility: visible; }
.modal-content { width: 600rpx; display: flex; flex-direction: column; align-items: center; position: relative; }
.modal-close { position: absolute; top: -50rpx; right: 0; width: 50rpx; height: 50rpx; display: flex; align-items: center; justify-content: center; }
.modal-close text { color: #fff; font-size: 36rpx; }
.modal-img { width: 600rpx; border-radius: 16rpx; }
.btn-save { margin-top: 24rpx; width: 360rpx; height: 76rpx; line-height: 76rpx; background: #2d8cf0; color: #fff; font-size: 28rpx; font-weight: bold; border-radius: 38rpx; border: none; }
.modal-tip { font-size: 22rpx; color: rgba(255,255,255,0.7); margin-top: 12rpx; }
