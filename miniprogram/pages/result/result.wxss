.container {
  padding: 30rpx;
  padding-bottom: 80rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.bg-shape {
  position: absolute;
  border-radius: 50%;
}

.shape-1 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, rgba(108, 92, 231, 0.08), transparent);
  top: -200rpx;
  right: -150rpx;
}

.shape-2 {
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255, 107, 157, 0.06), transparent);
  bottom: 200rpx;
  left: -150rpx;
}

/* 爱心展示区 */
.heart-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 0 30rpx;
  position: relative;
  z-index: 1;
}

.heart-glow {
  position: absolute;
  top: 30rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 71, 87, 0.15), transparent);
  animation: heartGlow 2s ease-in-out infinite;
}

@keyframes heartGlow {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.3); opacity: 0.4; }
}

.hearts-row {
  margin-bottom: 24rpx;
  position: relative;
  animation: heartBounce 0.8s ease;
}

@keyframes heartBounce {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.15); }
  100% { transform: scale(1); opacity: 1; }
}

.heart-emoji {
  font-size: 60rpx;
  letter-spacing: 12rpx;
}

.heart-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.heart-percent {
  font-size: 40rpx;
  font-weight: 800;
  color: #ff4757;
}

.score-badge {
  padding: 10rpx 36rpx;
  background: linear-gradient(135deg, rgba(108, 92, 231, 0.1), rgba(162, 155, 254, 0.1));
  border-radius: 30rpx;
  border: 1rpx solid rgba(108, 92, 231, 0.2);
}

.score-text {
  font-size: 28rpx;
  color: #6c5ce7;
  font-weight: 600;
}

/* 等级横幅 */
.level-banner {
  margin: 30rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 50%, #74b9ff 100%);
  box-shadow: 0 12rpx 40rpx rgba(108, 92, 231, 0.25);
  position: relative;
  z-index: 1;
}

.level-content {
  padding: 28rpx 36rpx;
  position: relative;
}

.level-content::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent, rgba(255,255,255,0.1), transparent);
  animation: levelShine 4s ease-in-out infinite;
}

@keyframes levelShine {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

.level-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1.7;
}

/* 结果卡片 */
.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(108, 92, 231, 0.08);
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.result-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.diagnosis-card::after {
  background: linear-gradient(90deg, #6c5ce7, #a29bfe, #74b9ff);
}

.prescription-card::after {
  background: linear-gradient(90deg, #ff6b9d, #ee5a82, #ff9a9e);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f8;
}

.header-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.diagnosis-icon-bg {
  background: rgba(108, 92, 231, 0.1);
}

.prescription-icon-bg {
  background: rgba(255, 107, 157, 0.1);
}

.header-icon {
  font-size: 32rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2d3436;
}

.card-body {
  padding: 0;
}

.card-content {
  font-size: 28rpx;
  color: #555;
  line-height: 2;
  white-space: pre-wrap;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.poster-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  background: linear-gradient(135deg, #ff6b9d 0%, #ee5a82 50%, #c44dff 100%);
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 157, 0.35);
  border: none;
  position: relative;
  overflow: hidden;
}

.poster-btn::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent, rgba(255,255,255,0.2), transparent);
  animation: btnShine 3s ease-in-out infinite;
}

@keyframes btnShine {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

.poster-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 157, 0.25);
}

.poster-btn-icon {
  font-size: 32rpx;
}

.restart-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 30rpx;
  background: #fff;
  color: #666;
  border: 2rpx solid #ebebf5;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.restart-btn:active {
  background: #f8f8fa;
  transform: scale(0.97);
}

.restart-icon {
  font-size: 28rpx;
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 36rpx;
  padding: 16rpx 30rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
  position: relative;
  z-index: 1;
}

/* 底部推荐 */
.recommend-section {
  margin-top: 50rpx;
  position: relative;
  z-index: 1;
}

.recommend-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.recommend-line {
  width: 80rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #ddd, transparent);
}

.recommend-title {
  font-size: 26rpx;
  color: #999;
}

.recommend-list {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.recommend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.recommend-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.08);
  transition: all 0.2s ease;
}

.recommend-icon-wrap:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(108, 92, 231, 0.12);
}

.recommend-icon {
  font-size: 44rpx;
}

.recommend-name {
  font-size: 24rpx;
  color: #666;
}


/* ========= 海报相关样式 ========= */

/* 隐藏的Canvas */
.poster-canvas {
  position: fixed;
  left: -9999rpx;
  top: 0;
  width: 750px;
  height: 1200px;
}

/* 海报弹窗 */
.poster-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.7);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.poster-modal.show {
  opacity: 1;
  visibility: visible;
}

.poster-modal-content {
  width: 620rpx;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  animation: posterPopIn 0.3s ease;
}

@keyframes posterPopIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

/* 关闭按钮 */
.poster-close {
  position: absolute;
  top: -60rpx;
  right: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  z-index: 10;
}

.poster-close text {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 海报图片 */
.poster-image {
  width: 620rpx;
  border-radius: 20rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

/* 底部操作 */
.poster-actions {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.save-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 400rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #6c5ce7 0%, #a29bfe 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 44rpx;
  border: none;
  box-shadow: 0 8rpx 30rpx rgba(108, 92, 231, 0.4);
}

.save-btn:active {
  transform: scale(0.96);
}

.save-icon {
  font-size: 30rpx;
}

.poster-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
