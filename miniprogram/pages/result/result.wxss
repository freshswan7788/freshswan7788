.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

/* 电量区域 */
.battery-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.battery-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.battery-percent {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.score-display {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
  background: rgba(102, 126, 234, 0.1);
  padding: 8rpx 30rpx;
  border-radius: 20rpx;
}

/* 等级卡片 */
.level-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 30rpx;
}

.level-text {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1.6;
}

/* 结果卡片 */
.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.card-body {
  padding: 0;
}

.card-content {
  font-size: 28rpx;
  color: #555;
  line-height: 2;
  white-space: pre-wrap;
}

/* 诊断卡片左侧标记 */
.diagnosis-card {
  border-left: 8rpx solid #667eea;
}

/* 处方卡片左侧标记 */
.prescription-card {
  border-left: 8rpx solid #ff6b9d;
}

/* 操作按钮 */
.action-buttons {
  margin-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.poster-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  background: linear-gradient(135deg, #ff6b9d 0%, #c471ed 100%) !important;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 157, 0.4) !important;
}

.restart-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.restart-icon {
  font-size: 28rpx;
}

/* 免责声明 */
.disclaimer {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 30rpx;
  padding: 16rpx;
}

/* 底部推荐 */
.recommend-section {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}

.recommend-title {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 24rpx;
}

.recommend-list {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.recommend-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 24rpx 36rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  font-size: 26rpx;
  color: #555;
}

.recommend-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}
