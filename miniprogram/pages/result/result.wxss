/* 结果页 - 竞品级设计 */
.page { min-height: 100vh; position: relative; }
.bg-layer { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: linear-gradient(180deg, #ffecd2 0%, #fff5f5 30%, #ffffff 60%); z-index: 0; }
.content { position: relative; z-index: 1; padding: 40rpx; }

/* 结果视觉区 */
.result-visual { display: flex; flex-direction: column; align-items: center; padding: 30rpx 0 20rpx; position: relative; }
.result-image { width: 320rpx; height: 320rpx; border-radius: 50%; background: rgba(255,255,255,0.5); box-shadow: 0 16rpx 48rpx rgba(252,182,159,0.3); }
.score-circle { position: absolute; bottom: 0; background: #fff; width: 120rpx; height: 120rpx; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 8rpx 30rpx rgba(255,107,138,0.25); border: 4rpx solid #ffe4e8; }
.score-num { font-size: 40rpx; font-weight: 900; color: #ff6b8a; line-height: 1; }
.score-unit { font-size: 20rpx; color: #ffb3c1; }

/* 等级区域 */
.level-area { display: flex; align-items: center; justify-content: center; gap: 16rpx; padding: 30rpx 0; }
.heart-icon { font-size: 48rpx; }
.level-label { font-size: 36rpx; font-weight: 800; color: #ff6b8a; }
.percent-text { font-size: 26rpx; color: #b8a9c9; background: #f8f0ff; padding: 6rpx 20rpx; border-radius: 20rpx; }

/* 卡片 */
.card { background: #fff; border-radius: 28rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.04); border: 2rpx solid #f5f0fa; }
.card-top { display: flex; align-items: center; gap: 12rpx; margin-bottom: 20rpx; padding-bottom: 16rpx; border-bottom: 2rpx dashed #f5f0fa; }
.card-emoji { font-size: 36rpx; }
.card-title { font-size: 32rpx; font-weight: 700; color: #4a3f5c; }
.card-body { font-size: 30rpx; color: #6b5f7a; line-height: 2; }

.diagnosis-card { border-left: 8rpx solid #ff9a9e; }
.prescription-card { border-left: 8rpx solid #a18cd1; }

/* 操作按钮 */
.actions { display: flex; flex-direction: column; gap: 20rpx; margin-top: 40rpx; }
.share-btn { width: 100%; height: 100rpx; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #ff6b8a, #ff9a9e); color: #fff; font-size: 32rpx; font-weight: 700; border-radius: 50rpx; border: none; box-shadow: 0 10rpx 30rpx rgba(255,107,138,0.3); }
.share-btn:active { transform: scale(0.97); }
.retry-btn { width: 100%; height: 88rpx; display: flex; align-items: center; justify-content: center; background: #fff; color: #9b8ab8; font-size: 30rpx; border-radius: 50rpx; border: 2rpx solid #ece4f5; }
.retry-btn:active { background: #faf5ff; }

/* 底部 */
.footer-text { text-align: center; font-size: 22rpx; color: #ccc; margin-top: 30rpx; }

/* 海报弹窗 */
.poster-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.65); opacity: 0; visibility: hidden; transition: all 0.3s ease; }
.poster-modal.show { opacity: 1; visibility: visible; }
.poster-modal-content { width: 620rpx; display: flex; flex-direction: column; align-items: center; position: relative; }
.poster-close { position: absolute; top: -60rpx; right: 0; width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.3); border-radius: 50%; }
.poster-close text { color: #fff; font-size: 32rpx; font-weight: bold; }
.poster-image { width: 620rpx; border-radius: 24rpx; box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2); }
.poster-actions { margin-top: 30rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.save-btn { width: 400rpx; height: 88rpx; display: flex; align-items: center; justify-content: center; background: #fff; color: #ff6b8a; font-size: 30rpx; font-weight: bold; border-radius: 44rpx; border: none; }
.save-btn:active { transform: scale(0.96); }
.poster-tip { font-size: 24rpx; color: rgba(255,255,255,0.7); }
