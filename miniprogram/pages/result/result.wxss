/* 结果页 - 卡通可爱风 */
.container {
  padding: 30rpx;
  padding-bottom: 80rpx;
  position: relative;
  overflow: hidden;
}

.bg-decoration { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; }
.bg-shape { position: absolute; border-radius: 50%; }
.shape-1 { width: 400rpx; height: 400rpx; background: radial-gradient(circle, rgba(255,154,158,0.1), transparent); top: -160rpx; right: -120rpx; }
.shape-2 { width: 300rpx; height: 300rpx; background: radial-gradient(circle, rgba(161,140,209,0.08), transparent); bottom: 200rpx; left: -100rpx; }

/* 爱心展示区 */
.heart-section { display: flex; flex-direction: column; align-items: center; padding: 50rpx 0 30rpx; position: relative; z-index: 1; }
.heart-glow { position: absolute; top: 10rpx; width: 320rpx; height: 320rpx; border-radius: 50%; background: radial-gradient(circle, rgba(255,107,138,0.2), transparent); animation: heartGlow 2s ease-in-out infinite; }
@keyframes heartGlow { 0%,100%{transform:scale(1);opacity:0.8} 50%{transform:scale(1.3);opacity:0.4} }


.hearts-row { margin-bottom: 24rpx; animation: heartBounce 0.8s ease; }
@keyframes heartBounce { 0%{transform:scale(0);opacity:0} 50%{transform:scale(1.15)} 100%{transform:scale(1);opacity:1} }
.heart-emoji { font-size: 160rpx; animation: heartbeat 1.5s ease-in-out infinite; }
@keyframes heartbeat { 0%,100%{transform:scale(1)} 15%{transform:scale(1.15)} 30%{transform:scale(1)} 45%{transform:scale(1.1)} 60%{transform:scale(1)} }
.heart-info { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.heart-percent { font-size: 44rpx; font-weight: 800; color: #ff6b8a; }
.score-badge { padding: 10rpx 36rpx; background: #fff0f3; border-radius: 30rpx; border: 2rpx solid #ffe4e8; }
.score-text { font-size: 28rpx; color: #ff6b8a; font-weight: 600; }

/* 等级横幅 */
.level-banner { margin: 30rpx 0; border-radius: 24rpx; overflow: hidden; background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #a18cd1 100%); box-shadow: 0 10rpx 30rpx rgba(255,154,158,0.3); position: relative; z-index: 1; }
.level-content { padding: 28rpx 36rpx; }
.level-text { color: #fff; font-size: 30rpx; font-weight: bold; line-height: 1.7; }


/* 结果卡片 */
.result-card { background: #fff; border-radius: 30rpx; padding: 36rpx; margin-bottom: 24rpx; box-shadow: 0 6rpx 24rpx rgba(255,154,158,0.1); position: relative; z-index: 1; overflow: hidden; border: 3rpx solid #ffe4e8; }
.result-card::after { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 8rpx; }
.diagnosis-card::after { background: linear-gradient(90deg, #ff9a9e, #fecfef, #a18cd1); }
.prescription-card::after { background: linear-gradient(90deg, #ff6b8a, #ff9a9e, #fecfef); }
.card-header { display: flex; align-items: center; margin-bottom: 24rpx; padding-bottom: 20rpx; border-bottom: 2rpx dashed #ffe4e8; }
.header-icon-wrap { width: 60rpx; height: 60rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; }
.diagnosis-icon-bg { background: #fff0f3; }
.prescription-icon-bg { background: #f3f0ff; }
.header-icon { font-size: 32rpx; }
.card-title { font-size: 34rpx; font-weight: bold; color: #4a3f5c; }
.card-body { padding: 0; }
.card-content { font-size: 32rpx; color: #5a4f6a; line-height: 2; white-space: pre-wrap; }


/* 操作按钮 */
.action-buttons { margin-top: 40rpx; display: flex; flex-direction: column; align-items: center; gap: 20rpx; position: relative; z-index: 1; }
.poster-btn { width: 100%; height: 100rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; border-radius: 60rpx; font-size: 32rpx; font-weight: bold; color: #fff; background: linear-gradient(135deg, #ff6b8a 0%, #ff9a9e 50%, #fecfef 100%); box-shadow: 0 10rpx 30rpx rgba(255,107,138,0.3); border: none; }
.poster-btn:active { transform: scale(0.97); }
.poster-btn-icon { font-size: 32rpx; }
.restart-btn { width: 100%; height: 88rpx; display: flex; align-items: center; justify-content: center; gap: 12rpx; font-size: 30rpx; background: #fff; color: #9b8ab8; border: 3rpx solid #f0e8f5; border-radius: 60rpx; box-shadow: 0 4rpx 12rpx rgba(161,140,209,0.08); }
.restart-btn:active { background: #fef9ff; transform: scale(0.97); }
.restart-icon { font-size: 28rpx; }

/* 免责声明 */
.disclaimer { text-align: center; font-size: 24rpx; color: #c9b8d9; margin-top: 36rpx; padding: 16rpx 30rpx; background: #fff; border-radius: 20rpx; border: 2rpx solid #f5eeff; position: relative; z-index: 1; }

/* 底部推荐 */
.recommend-section { margin-top: 50rpx; position: relative; z-index: 1; }
.recommend-header { display: flex; align-items: center; justify-content: center; gap: 20rpx; margin-bottom: 30rpx; }
.recommend-line { width: 60rpx; height: 3rpx; background: #ffe4e8; border-radius: 2rpx; }
.recommend-title { font-size: 26rpx; color: #c9b8d9; }
.recommend-list { display: flex; justify-content: center; gap: 40rpx; }
.recommend-item { display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.recommend-icon-wrap { width: 100rpx; height: 100rpx; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center; box-shadow: 0 6rpx 20rpx rgba(255,154,158,0.12); border: 3rpx solid #ffe4e8; }
.recommend-icon { font-size: 44rpx; }
.recommend-name { font-size: 24rpx; color: #9b8ab8; }


/* 海报相关样式 */
.poster-canvas { position: fixed; left: -9999rpx; top: 0; width: 750px; height: 1200px; }
.poster-modal { position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 9999; display: flex; align-items: center; justify-content: center; background: rgba(0,0,0,0.6); opacity: 0; visibility: hidden; transition: all 0.3s ease; }
.poster-modal.show { opacity: 1; visibility: visible; }
.poster-modal-content { width: 620rpx; max-height: 90vh; display: flex; flex-direction: column; align-items: center; position: relative; animation: posterPopIn 0.3s ease; }
@keyframes posterPopIn { from{transform:scale(0.8);opacity:0} to{transform:scale(1);opacity:1} }
.poster-close { position: absolute; top: -60rpx; right: 0; width: 56rpx; height: 56rpx; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.3); border-radius: 50%; z-index: 10; }
.poster-close text { color: #fff; font-size: 32rpx; font-weight: bold; }
.poster-image { width: 620rpx; border-radius: 24rpx; box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2); }
.poster-actions { margin-top: 30rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.save-btn { display: flex; align-items: center; justify-content: center; gap: 12rpx; width: 400rpx; height: 88rpx; background: linear-gradient(135deg, #ff9a9e, #fecfef); color: #fff; font-size: 30rpx; font-weight: bold; border-radius: 44rpx; border: none; box-shadow: 0 8rpx 24rpx rgba(255,154,158,0.4); }
.save-btn:active { transform: scale(0.96); }
.save-icon { font-size: 30rpx; }
.poster-tip { font-size: 24rpx; color: rgba(255,255,255,0.7); }


/* 卡通漂浮元素 */
.cartoon-floats { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; z-index: 0; }
.cf-item { position: absolute; animation: cfFloat 5s ease-in-out infinite; }
.cf-1 { font-size: 36rpx; top: 100rpx; right: 40rpx; animation-delay: 0s; }
.cf-2 { font-size: 28rpx; top: 260rpx; left: 30rpx; animation-delay: 1s; }
.cf-3 { font-size: 32rpx; bottom: 500rpx; right: 50rpx; animation-delay: 2s; }
.cf-4 { font-size: 26rpx; bottom: 350rpx; left: 50rpx; animation-delay: 3s; }
.cf-5 { font-size: 30rpx; bottom: 200rpx; right: 70rpx; animation-delay: 4s; }
@keyframes cfFloat { 0%,100%{transform:translateY(0) scale(1);opacity:0.5} 50%{transform:translateY(-20rpx) scale(1.1);opacity:0.9} }

/* 爱心旁装饰星星 */
.deco-star { position: absolute; animation: starTwinkle 2s ease-in-out infinite; }
.deco-1 { font-size: 28rpx; top: 30rpx; right: 80rpx; animation-delay: 0s; }
.deco-2 { font-size: 24rpx; top: 60rpx; left: 70rpx; animation-delay: 0.5s; }
.deco-3 { font-size: 22rpx; bottom: 30rpx; right: 100rpx; animation-delay: 1s; }
@keyframes starTwinkle { 0%,100%{transform:scale(1) rotate(0deg);opacity:0.4} 50%{transform:scale(1.3) rotate(20deg);opacity:1} }
