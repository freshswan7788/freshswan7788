<view class="container">
  <!-- 电量图标 -->
  <view class="battery-section">
    <view class="battery-icon">{{batteryIcon}}</view>
    <view class="battery-percent">{{batteryPercent}}</view>
    <view class="score-display">总分：{{score}}分</view>
  </view>

  <!-- 等级标题 -->
  <view class="level-card">
    <text class="level-text">{{level}}</text>
  </view>

  <!-- 诊断结果 -->
  <view class="result-card diagnosis-card">
    <view class="card-header">
      <view class="card-icon">🩺</view>
      <text class="card-title">诊断：</text>
    </view>
    <view class="card-body">
      <text class="card-content">{{diagnosis}}</text>
    </view>
  </view>

  <!-- 关系保鲜方 -->
  <view class="result-card prescription-card">
    <view class="card-header">
      <view class="card-icon">💊</view>
      <text class="card-title">关系保鲜方：</text>
    </view>
    <view class="card-body">
      <text class="card-content">{{prescription}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn-primary poster-btn" bindtap="generatePoster">生成海报分享</button>
    <button class="restart-btn" bindtap="restartTest">
      <text>再测一次</text>
      <text class="restart-icon">🔄</text>
    </button>
  </view>

  <!-- 免责声明 -->
  <view class="disclaimer">
    <text>{{disclaimer}}</text>
  </view>

  <!-- 底部导航推荐 -->
  <view class="recommend-section">
    <view class="recommend-title">更多趣味测试</view>
    <view class="recommend-list">
      <view class="recommend-item">
        <text class="recommend-icon">🔮</text>
        <text>测运势</text>
      </view>
      <view class="recommend-item">
        <text class="recommend-icon">📛</text>
        <text>起名字</text>
      </view>
      <view class="recommend-item">
        <text class="recommend-icon">📖</text>
        <text>百家姓</text>
      </view>
    </view>
  </view>
</view>
