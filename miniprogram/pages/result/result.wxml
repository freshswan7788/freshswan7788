<view class="page">
  <!-- 渐变背景 -->
  <view class="bg-layer"></view>

  <view class="content">
    <!-- 顶部结果插画 -->
    <view class="result-visual">
      <image class="result-image" src="{{resultImg}}" mode="aspectFit"></image>
      <view class="score-circle">
        <text class="score-num">{{score}}</text>
        <text class="score-unit">分</text>
      </view>
    </view>

    <!-- 爱心+等级 -->
    <view class="level-area">
      <text class="heart-icon">{{batteryIcon}}</text>
      <text class="level-label">{{levelShort}}</text>
      <text class="percent-text">{{batteryPercent}}</text>
    </view>

    <!-- 诊断卡片 -->
    <view class="card diagnosis-card">
      <view class="card-top">
        <text class="card-emoji">🩺</text>
        <text class="card-title">诊断</text>
      </view>
      <text class="card-body">{{diagnosis}}</text>
    </view>

    <!-- 保鲜方卡片 -->
    <view class="card prescription-card">
      <view class="card-top">
        <text class="card-emoji">💊</text>
        <text class="card-title">关系保鲜方</text>
      </view>
      <text class="card-body">{{prescription}}</text>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="share-btn" bindtap="generatePoster">🎨 生成海报分享</button>
      <button class="retry-btn" bindtap="restartTest">🔄 再测一次</button>
    </view>

    <!-- 底部 -->
    <view class="footer-text">
      <text>{{disclaimer}}</text>
    </view>
  </view>

  <!-- 隐藏Canvas -->
  <canvas type="2d" id="posterCanvas" style="position:fixed;left:-9999px;top:0;width:750px;height:1200px;"></canvas>

  <!-- 海报弹窗 -->
  <view class="poster-modal {{showPoster ? 'show' : ''}}" bindtap="closePoster">
    <view class="poster-modal-content" catchtap="preventTap">
      <view class="poster-close" bindtap="closePoster"><text>✕</text></view>
      <image class="poster-image" src="{{posterUrl}}" mode="widthFix" show-menu-by-longpress="{{true}}"></image>
      <view class="poster-actions">
        <button class="save-btn" bindtap="savePoster">💾 保存到相册</button>
        <text class="poster-tip">长按图片可直接分享给好友</text>
      </view>
    </view>
  </view>
</view>
