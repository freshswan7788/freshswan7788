.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
  position: relative;
  overflow: hidden;
}

/* 顶部装饰圆 */
.top-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.15;
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  background: #6c5ce7;
  top: -100rpx;
  right: -80rpx;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  background: #a29bfe;
  top: 60rpx;
  left: -60rpx;
}

.circle-3 {
  width: 150rpx;
  height: 150rpx;
  background: #74b9ff;
  top: 200rpx;
  right: 100rpx;
}

/* 标题区域 */
.header-section {
  text-align: center;
  padding: 60rpx 0 40rpx;
  position: relative;
  z-index: 1;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  animation: heartbeat 2s ease-in-out infinite;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.header-title {
  font-size: 44rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #6c5ce7, #a29bfe);
  -webkit-background-clip: text;
  color: transparent;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #888;
  letter-spacing: 2rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(108, 92, 231, 0.08);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #6c5ce7, #a29bfe, #74b9ff);
}

/* 卡片徽章 */
.card-badge {
  display: inline-block;
  font-size: 26rpx;
  font-weight: bold;
  color: #6c5ce7;
  margin-bottom: 20rpx;
  padding: 6rpx 20rpx;
  background: rgba(108, 92, 231, 0.08);
  border-radius: 20rpx;
}

.info-badge {
  color: #0984e3;
  background: rgba(9, 132, 227, 0.08);
}

.legal-badge {
  color: #e17055;
  background: rgba(225, 112, 85, 0.08);
}

.score-badge {
  color: #00b894;
  background: rgba(0, 184, 148, 0.08);
}

.card-content {
  font-size: 28rpx;
  color: #555;
  line-height: 2;
}

.highlight {
  color: #6c5ce7;
  font-weight: bold;
  padding: 0 4rpx;
}

/* 提示文字 */
.card-tip {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #eee;
  font-size: 26rpx;
  color: #e17055;
  line-height: 1.6;
}

.tip-icon {
  margin-right: 10rpx;
  flex-shrink: 0;
}

/* 法律声明特殊样式 */
.legal-card::before {
  background: linear-gradient(90deg, #e17055, #fab1a0);
}

.legal-text {
  font-size: 26rpx;
  color: #666;
}

/* 评分列表 */
.score-card::before {
  background: linear-gradient(90deg, #00b894, #55efc4);
}

.score-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.score-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #f8f9ff;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.score-num {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: linear-gradient(135deg, #6c5ce7, #a29bfe);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(108, 92, 231, 0.3);
}

.score-desc {
  font-size: 28rpx;
  color: #555;
}

/* 按钮区域 */
.btn-wrapper {
  margin-top: 50rpx;
  display: flex;
  justify-content: center;
}

.start-btn {
  width: 500rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 36rpx;
}

/* 底部信息 */
.footer-info {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 30rpx;
  padding: 20rpx 0;
}
