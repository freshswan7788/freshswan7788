/* 首页 - 竞品级设计 */
.page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.bg-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(160deg, #ffecd2 0%, #fcb69f 40%, #ff9a9e 70%, #fecfef 100%);
  z-index: 0;
}

.content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  min-height: 100vh;
}

/* 主视觉插画 */
.hero-image-wrap {
  width: 100%;
  height: 520rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.hero-image {
  width: 460rpx;
  height: 460rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  box-shadow: 0 20rpx 60rpx rgba(252, 182, 159, 0.4);
}

/* 标题区 */
.title-area {
  text-align: center;
  margin-bottom: 50rpx;
}

.main-title {
  display: block;
  font-size: 54rpx;
  font-weight: 900;
  color: #fff;
  text-shadow: 0 4rpx 20rpx rgba(255,107,138,0.3);
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.sub-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  letter-spacing: 2rpx;
}

/* 亮点标签 */
.tags-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.tag-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.25);
  backdrop-filter: blur(10rpx);
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
}

.tag-emoji {
  font-size: 36rpx;
}

.tag-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

/* 开始按钮 */
.start-btn {
  width: 560rpx;
  height: 108rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #fff;
  border-radius: 54rpx;
  border: none;
  box-shadow: 0 16rpx 48rpx rgba(255,107,138,0.35);
  margin-bottom: 40rpx;
}

.start-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #ff6b8a;
}

.start-arrow {
  font-size: 36rpx;
  color: #ff6b8a;
}

.start-btn:active {
  transform: scale(0.96);
  box-shadow: 0 8rpx 24rpx rgba(255,107,138,0.3);
}

/* 底部 */
.bottom-note {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
