.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
}

/* 卡片通用样式 */
.declaration-card,
.info-card,
.legal-card,
.score-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.card-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.card-sub {
  font-size: 26rpx;
  color: #888;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #eee;
}

.highlight {
  color: #667eea;
  font-weight: bold;
}

/* 法律声明 */
.legal-card {
  border-left: 6rpx solid #ff9800;
}

.legal-text {
  font-size: 26rpx;
  color: #666;
}

/* 评分说明 */
.score-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.score-label {
  background: #667eea;
  color: #fff;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 20rpx;
  min-width: 80rpx;
  text-align: center;
}

.score-desc {
  font-size: 28rpx;
  color: #555;
}

/* 按钮区域 */
.btn-wrapper {
  margin-top: 40rpx;
  display: flex;
  justify-content: center;
}

.start-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 34rpx;
}
