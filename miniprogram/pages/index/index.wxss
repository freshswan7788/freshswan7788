/* 首页 - 简约大气卡通风 */
.container { padding: 30rpx; padding-bottom: 80rpx; position: relative; overflow: hidden; min-height: 100vh; }

/* 漂浮装饰元素 */
.floating-elements { position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; z-index: 0; }
.float-item { position: absolute; animation: floatUp 6s ease-in-out infinite; }
.float-1 { font-size: 44rpx; top: 80rpx; left: 40rpx; animation-delay: 0s; }
.float-2 { font-size: 36rpx; top: 160rpx; right: 60rpx; animation-delay: 1s; }
.float-3 { font-size: 40rpx; top: 400rpx; left: 60rpx; animation-delay: 2s; }
.float-4 { font-size: 32rpx; top: 300rpx; right: 40rpx; animation-delay: 3s; }
.float-5 { font-size: 38rpx; bottom: 300rpx; left: 80rpx; animation-delay: 4s; }
.float-6 { font-size: 34rpx; bottom: 400rpx; right: 80rpx; animation-delay: 5s; }

@keyframes floatUp {
  0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
  50% { transform: translateY(-30rpx) rotate(10deg); opacity: 1; }
}

/* 主视觉 */
.hero-section { text-align: center; padding: 100rpx 0 60rpx; position: relative; z-index: 1; }
.hero-icon { font-size: 140rpx; margin-bottom: 30rpx; animation: heroFloat 3s ease-in-out infinite; }
@keyframes heroFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-20rpx)} }
.hero-title { font-size: 52rpx; font-weight: 800; color: #ff6b8a; margin-bottom: 16rpx; letter-spacing: 4rpx; }
.hero-desc { font-size: 30rpx; color: #b8a9c9; letter-spacing: 2rpx; }

/* 卡通插画卡片 */
.feature-card { background: #fff; border-radius: 36rpx; padding: 40rpx; margin: 50rpx 0 40rpx; box-shadow: 0 8rpx 30rpx rgba(255,107,138,0.12); border: 3rpx solid #ffe4e8; position: relative; z-index: 1; overflow: hidden; }
.feature-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 8rpx; background: linear-gradient(90deg, #ff6b8a, #ffa3b5, #ffccd5); }
.card-illustration { display: flex; align-items: center; justify-content: center; padding: 30rpx 0; position: relative; }
.illust-main { font-size: 100rpx; animation: pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.1)} }
.illust-sub-1 { position: absolute; top: 10rpx; right: 120rpx; font-size: 40rpx; animation: orbit 4s linear infinite; }
.illust-sub-2 { position: absolute; bottom: 10rpx; left: 120rpx; font-size: 36rpx; animation: orbit 4s linear infinite reverse; }
@keyframes orbit { 0%{transform:translateY(0) rotate(0deg)} 50%{transform:translateY(-10rpx) rotate(180deg)} 100%{transform:translateY(0) rotate(360deg)} }
.card-info { text-align: center; margin-top: 16rpx; }
.card-tag { display: inline-block; background: #fff0f3; color: #ff6b8a; font-size: 26rpx; font-weight: bold; padding: 8rpx 28rpx; border-radius: 30rpx; border: 2rpx solid #ffe4e8; margin-bottom: 16rpx; }
.card-text { font-size: 30rpx; color: #5a4f6a; line-height: 1.8; }

/* 特色说明行 */
.features-row { display: flex; justify-content: space-around; padding: 20rpx 0 40rpx; position: relative; z-index: 1; }
.feature-item { display: flex; flex-direction: column; align-items: center; gap: 10rpx; }
.feature-icon { font-size: 48rpx; }
.feature-label { font-size: 24rpx; color: #9b8ab8; font-weight: 500; }

/* 按钮 */
.btn-wrapper { display: flex; justify-content: center; position: relative; z-index: 1; margin-top: 20rpx; }
.start-btn { width: 520rpx; height: 110rpx; line-height: 110rpx; font-size: 36rpx; border-radius: 60rpx; }

/* 底部 */
.footer-note { text-align: center; font-size: 22rpx; color: #ccc; margin-top: 40rpx; position: relative; z-index: 1; }
