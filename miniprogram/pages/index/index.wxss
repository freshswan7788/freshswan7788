/* 首页 - 卡通可爱风 */
.container {
  padding: 30rpx;
  padding-bottom: 120rpx;
  position: relative;
  overflow: hidden;
}

/* 顶部装饰 - 可爱泡泡 */
.top-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
  pointer-events: none;
}

.deco-circle {
  position: absolute;
  border-radius: 50%;
  opacity: 0.25;
}

.circle-1 {
  width: 260rpx;
  height: 260rpx;
  background: #ffb8c6;
  top: -80rpx;
  right: -60rpx;
}

.circle-2 {
  width: 180rpx;
  height: 180rpx;
  background: #ffd6e0;
  top: 80rpx;
  left: -40rpx;
}

.circle-3 {
  width: 120rpx;
  height: 120rpx;
  background: #ffe0b2;
  top: 220rpx;
  right: 120rpx;
}

/* 标题区域 */
.header-section {
  text-align: center;
  padding: 60rpx 0 40rpx;
  position: relative;
  z-index: 1;
}

.header-icon {
  font-size: 90rpx;
  margin-bottom: 16rpx;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.header-title {
  font-size: 46rpx;
  font-weight: 800;
  color: #ff6b8a;
  margin-bottom: 12rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #b8a9c9;
  letter-spacing: 2rpx;
}

/* 通用卡片 - 可爱圆角 */
.card {
  background: #fff;
  border-radius: 30rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(255, 154, 158, 0.12);
  position: relative;
  overflow: hidden;
  border: 3rpx solid #ffe4e8;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: linear-gradient(90deg, #ff9a9e, #fecfef, #ffdde1);
  border-radius: 30rpx 30rpx 0 0;
}

/* 卡片徽章 */
.card-badge {
  display: inline-block;
  font-size: 26rpx;
  font-weight: bold;
  color: #ff6b8a;
  margin-bottom: 20rpx;
  padding: 8rpx 24rpx;
  background: #fff0f3;
  border-radius: 30rpx;
  border: 2rpx solid #ffe4e8;
}

.info-badge {
  color: #7c6faa;
  background: #f3f0ff;
  border-color: #e8e0ff;
}

.legal-badge {
  color: #ff8c42;
  background: #fff5ec;
  border-color: #ffe4cc;
}

.score-badge {
  color: #4ecdc4;
  background: #e8fffe;
  border-color: #c8f7f4;
}

.card-content {
  font-size: 30rpx;
  color: #5a4f6a;
  line-height: 2;
}

.highlight {
  color: #ff6b8a;
  font-weight: bold;
  padding: 0 4rpx;
}

/* 提示文字 */
.card-tip {
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed #ffe4e8;
  font-size: 26rpx;
  color: #ff8c42;
  line-height: 1.6;
}

.tip-icon {
  margin-right: 10rpx;
  flex-shrink: 0;
}

/* 法律声明 */
.legal-card {
  border-color: #ffe4cc;
}

.legal-card::before {
  background: linear-gradient(90deg, #ff8c42, #ffb74d, #ffe0b2);
}

.legal-text {
  font-size: 26rpx;
  color: #7a6b5a;
}

/* 评分列表 */
.score-card {
  border-color: #c8f7f4;
}

.score-card::before {
  background: linear-gradient(90deg, #4ecdc4, #88e8df, #b2f5ea);
}

.score-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.score-item {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fef9ff;
  border-radius: 20rpx;
  border: 2rpx solid #f5eeff;
}

.score-num {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background: linear-gradient(135deg, #ff9a9e, #fecfef);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 50%;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(255, 154, 158, 0.3);
}

.score-desc {
  font-size: 30rpx;
  color: #5a4f6a;
}

/* 按钮区域 */
.btn-wrapper {
  margin-top: 50rpx;
  display: flex;
  justify-content: center;
}

.start-btn {
  width: 500rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 36rpx;
}

/* 底部信息 */
.footer-info {
  text-align: center;
  font-size: 24rpx;
  color: #c9b8d9;
  margin-top: 30rpx;
  padding: 20rpx 0;
}
