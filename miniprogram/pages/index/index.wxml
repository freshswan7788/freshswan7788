<view class="page">
  <!-- 渐变背景层 -->
  <view class="bg-layer"></view>

  <!-- 主内容 -->
  <view class="content">
    <!-- 主视觉插画 -->
    <view class="hero-image-wrap">
      <image class="hero-image" src="{{heroImg}}" mode="aspectFit"></image>
    </view>

    <!-- 标题区 -->
    <view class="title-area">
      <text class="main-title">两性情感计算器</text>
      <text class="sub-title">2分钟测出你的爱情温度</text>
    </view>

    <!-- 亮点标签 -->
    <view class="tags-row">
      <view class="tag-item">
        <text class="tag-emoji">🔒</text>
        <text class="tag-text">隐私安全</text>
      </view>
      <view class="tag-item">
        <text class="tag-emoji">🎯</text>
        <text class="tag-text">10维度分析</text>
      </view>
      <view class="tag-item">
        <text class="tag-emoji">💊</text>
        <text class="tag-text">专属处方</text>
      </view>
    </view>

    <!-- 开始按钮 -->
    <button class="start-btn" bindtap="startTest">
      <text class="start-text">开始测试</text>
      <text class="start-arrow">→</text>
    </button>

    <!-- 底部信息 -->
    <view class="bottom-note">
      <text>仅供娱乐 · 不收集隐私 · 完全免费</text>
    </view>
  </view>
</view>
